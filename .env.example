# NewsNavigator AI - Environment Configuration Example
# Copy this file to .env and fill in your keys.

# ── LLM PROVIDERS ──────────────────────────────────────────
# Prioritized: Groq -> Gemini -> Anthropic

# Groq (Fastest/Primary) - Get keys at https://console.groq.com/
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.1-8b-instant
GROQ_MODEL_FALLBACK=llama3-8b-8192

# Gemini (Fallback) - Get keys at https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-1.5-flash

# Anthropic (Final Fallback) - Get keys at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here
CLAUDE_MODEL=claude-3-5-sonnet-latest

# ── SEARCH APIS ─────────────────────────────────────────────
# All 3 run in parallel for cross-validated news intelligence.

# Tavily (Premium News Search) - Get key at https://tavily.com/
TAVILY_API_KEY=tvly-your_key_here

# Serper (Google Search API) - Get key at https://serper.dev/
SERPER_API_KEY=your_serper_key_here

# NewsAPI (News Aggregator) - Get key at https://newsapi.org/
NEWSAPI_KEY=your_newsapi_key_here

# ── DATABASE & PERSISTENCE ──────────────────────────────────

# Neon Postgres (Recommended) or local Postgres
DATABASE_URL=postgres://user:pass@host:5432/dbname?sslmode=require

# Mem0 (Long-term Persona Memory) - Get key at https://mem0.ai/
MEM0_API_KEY=m0-your_key_here

# ── AUDIO & VOICE ───────────────────────────────────────────

# ElevenLabs (Premium Audio) - Get key at https://elevenlabs.io/
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# ── PATHS ───────────────────────────────────────────────────
# Path to the ingested news atoms JSONL file
ATOMS_PATH=./data/atoms.jsonl
